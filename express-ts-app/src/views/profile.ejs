<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">
  <div class="card mx-auto" style="max-width: 500px;">
    <div class="card-header bg-primary text-white">
      <h3>Профиль студента</h3>
    </div>
    <div class="card-body">
      <p><strong>ФИО:</strong> <%= student.last_name %> <%= student.first_name %></p>
      <p><strong>Email:</strong> <%= student.email %></p>
      <p><strong>Группа:</strong> <%= student.group_name || 'Без группы' %></p>
      <p><strong>Год поступления:</strong> <%= student.enrollment_year %></p>
    </div>
    <div class="card-footer text-end">
      <a href="/students" class="btn btn-secondary">Назад к списку</a>
    </div>
  </div>
</body>
</html>
