<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-4">
  <h1 class="mb-4">Добавить нового студента</h1>
  
  <form action="/students" method="POST" style="max-width: 600px;">
    <div class="mb-3">
      <label class="form-label">Имя</label>
      <input type="text" name="first_name" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Фамилия</label>
      <input type="text" name="last_name" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Группа</label>
      <select name="group_id" class="form-select">
        <option value="">-- Выберите группу --</option>
        <% groups.forEach(group => { %>
          <option value="<%= group.id %>"><%= group.group_name %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Год поступления</label>
      <input type="number" name="enrollment_year" class="form-control" value="2026" required>
    </div>
    <button type="submit" class="btn btn-success">Создать</button>
    <a href="/students" class="btn btn-secondary">Отмена</a>
  </form>
</body>
</html>
