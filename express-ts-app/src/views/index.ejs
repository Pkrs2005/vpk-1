<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Учет студентов</h1>
    <a href="/students/new" class="btn btn-success">Добавить студента</a>
  </div>

  <form method="GET" action="/students" class="row g-3 mb-4">
    <div class="col-auto">
      <select name="group_id" class="form-select" onchange="this.form.submit()">
        <option value="">Все группы</option>
        <% groups.forEach(group => { %>
          <option value="<%= group.id %>" <%= selectedGroupId == group.id ? 'selected' : '' %>>
            <%= group.group_name %> (<%= group.faculty %>)
          </option>
        <% }) %>
      </select>
    </div>
  </form>

  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>ФИО</th>
        <th>Email</th>
        <th>Группа</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% if (students.length === 0) { %>
        <tr><td colspan="4" class="text-center">Студенты не найдены</td></tr>
      <% } %>
      <% students.forEach(student => { %>
        <tr>
          <td><%= student.last_name %> <%= student.first_name %></td>
          <td><%= student.email %></td>
          <td><%= student.group_name || '—' %></td>
          <td><a href="/students/<%= student.id %>" class="btn btn-sm btn-primary">Профиль</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
