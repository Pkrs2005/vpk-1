<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>

<h1>Авторизация</h1>

<form action="/login" method="POST">

    <input
        type="text"
        name="login"
        placeholder="Логин"
        required
    >

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="Пароль"
        required
    >

    <br><br>

    <button type="submit">
        Войти
    </button>

</form>

</body>
</html>